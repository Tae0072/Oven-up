# 서버 환경변수 예시 파일 (값 없이 "키 이름"만 공유용)
# 실제 값은 각자 로컬의 .env 에 넣고, .env 는 커밋하지 않습니다. (06_Git_PR_규칙 §8)
# 아래 값들은 로드맵 뒤 단계(DB, 결제, 소셜로그인)에서 실제로 사용됩니다.

# --- DB (로드맵 3단계에서 사용) ---
DB_URL=jdbc:mysql://localhost:3306/ovenup
DB_USERNAME=
DB_PASSWORD=

# --- 인증 (JWT) ---
JWT_SECRET=

# --- 결제 (PortOne, 로드맵 6단계) ---
PORTONE_API_KEY=
PORTONE_API_SECRET=

# --- 소셜 로그인 (로드맵 6단계) ---
KAKAO_REST_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
